{
  "name": "setup-dotenv",
  "version": "2.0.0",
  "description": "A CLI tool for setting up and managing .env files.",
  "keywords": [
    "dotenv",
    "environment",
    "setup",
    "sync",
    "template",
    "variables"
  ],
  "homepage": "https://github.com/venables/setup-dotenv#readme",
  "bugs": "https://github.com/venables/setup-dotenv/issues",
  "license": "MIT",
  "author": "Matt Venables <matt@venabl.es>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/venables/setup-dotenv.git"
  },
  "bin": {
    "setup-dotenv": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun test",
    "clean": "git clean -xdf node_modules/.cache dist",
    "cli": "bun run ./src/index.ts",
    "fix": "bun run format && bun run lint:fix",
    "format": "oxfmt",
    "format:check": "bun run format -- --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "bun run lint -- --fix --fix-suggestions",
    "lint:fixall": "bun run lint:fix -- --fix-dangerously",
    "nuke": "bun run clean && git clean -xdf node_modules",
    "outdated": "bunx npm-check-updates --interactive --format group",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit --pretty"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "dotenv": "^17.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.19",
    "@types/node": "^24.2.1",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "latest",
    "publint": "latest",
    "tsdown": "^0.13.4",
    "typescript": "^5"
  }
}
